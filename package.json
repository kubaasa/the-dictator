{
  "name": "the-dictator",
  "productName": "The Dictator",
  "version": "1.2.9",
  "description": "Voice dictation app with AI-powered transcription for Windows",
  "main": "dist/main/main.js",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "vite build -c vite.renderer.config.ts && vite build -c vite.main.config.ts && vite build -c vite.preload.config.ts",
    "dist": "npm run build && electron-builder --win nsis",
    "publish": "npm run build && electron-builder --win nsis --publish always",
    "lint": "eslint --ext .ts,.tsx .",
    "rebuild": "electron-rebuild -f -w better-sqlite3,uiohook-napi",
    "postinstall": "node scripts/patch-electron-icon.js"
  },
  "keywords": [],
  "author": {
    "name": "Jakub Bruniecki",
    "email": "jakub.bruniecki@plus.pl"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "@sentry/cli": "^3.3.3",
    "@sentry/vite-plugin": "^5.1.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "electron": "40.7.0",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "~4.5.4",
    "vite": "^6.4.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@huggingface/transformers": "^3.8.1",
    "@sentry/electron": "^7.10.0",
    "better-sqlite3": "^12.6.2",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "openai": "^6.27.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uiohook-napi": "^1.5.4"
  }
}
